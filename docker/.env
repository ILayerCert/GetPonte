# =============================================================================
# Ponte POC — Environment Variables
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
# =============================================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=ponte
POSTGRES_USER=ponte
POSTGRES_PASSWORD=ponte_dev_password

# ---------- Backend ----------
JWT_SECRET=ponte-dev-secret-change-in-production
# DATABASE_URL is built automatically from the Postgres vars above

# ---------- Signaling (mediasoup) ----------
# Public IP that browsers will use to reach the media server.
# Set this to your server's public IP in cloud/VPS deployments.
# For local development, 127.0.0.1 works fine.
ANNOUNCED_IP=192.168.2.30

# ---------- Frontend ----------
VITE_API_URL=http://192.168.2.30:8080
VITE_WS_URL=ws://192.168.2.30:8080
VITE_SIGNALING_URL=ws://192.168.2.30:4100
